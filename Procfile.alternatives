# Option 1: Custom startup script (current)
web: bash start.sh

# Option 2: Apache startup
# web: bash start-apache.sh

# Option 3: Simple PHP server
# web: php server.php

# Option 4: Direct artisan serve with explicit port
# web: php artisan serve --host=0.0.0.0 --port=8000

# Option 5: Built-in PHP server
# web: php -S 0.0.0.0:$PORT -t public 